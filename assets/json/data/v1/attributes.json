  "hrefhost": {
    "category": "configuration",
    "description_short": "Sets the base URL based on host match.",
    "example": "<base hrefhost=\"localhost:https://example.com/\">\n<a sethref=\"page.html\">Go to Page</a>"
  },
  "if": {
    "category": "logic",
    "description_short": "Conditionally executes actions based on a comparison.",
    "example": "<input id=\"myage\" type=\"number\" setvalue=\"25\">\n<button click=\"if:([#myage]>[18])/settext:#output:[Adult]?settext:#output:[Minor]\">Check</button>\n<label id=\"output\"></label>",
    "values": [
      ": (equal)",
      "! (not equal)",
      "> (greater than)",
      "< (less than)",
      "~ (contains)",
      "!~ (not contains)",
      "& (AND)",
      "| (OR)"
    ]
  },
  "include": {
    "category": "content",
    "description_short": "Includes another internal HTML file or page fragment into the element.",
    "example": "<div include=\"assets/html/dummy.html\"></div>"
  },
  "insertbeforebegin": {
    "category": "content",
    "description_short": "Inserts new content immediately before the element.",
