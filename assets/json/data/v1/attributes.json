  "navigate-go": {
    "category": "interactive",
    "module": "navigate",
    "description_short": "Programmatically triggers navigation as if a user clicked a link. Loads the target page via the Navigate module into the specified container without a full page reload."
  },
  "onconfirm": {
    "category": "event",
    "description_short": "Triggered when the user confirms an action in a confirmation dialog.",
    "example": "<button click=\"confirm:[Are you sure?]\" onconfirm=\"settext:[Confirmed!]\">Confirm Action</button>",
    "depends_on": [
      "confirm"
    ]
  },
  "onconfirmvalue": {
    "category": "event",
    "description_short": "Triggered when a confirmation dialog is accepted; typically used to pass a value or trigger chained actions.",
    "example": "<button click=\"confirm:[Are you sure?]\" onconfirmvalue=\"true;settext:[Confirmed with yes]\">Delete Item</button>",
    "depends_on": [
      "confirm"
    ]
  },
  "onclicked": {
    "category": "event",
    "description_short": "Triggered when the element is clicked.",
    "example": "<button click=\"sethtml:[Button clicked!]\" onclicked=\"insertbeforeend:[ Added after]\">Click me</button>",
    "depends_on": [
      "click"
    ]
  },
  "onenabled": {
    "category": "event",
    "description_short": "Triggered when the element or feature becomes enabled.",
    "example": "<input type=\"checkbox\" click=\"enable\" onenabled=\"insertbeforebegin:[Enabled!]\"> Enable me",
    "depends_on": [
      "enable"
    ],
    "see_also": [
      "ondisabled"
    ]
  },
  "ondisabled": {
    "category": "event",
    "description_short": "Triggered when the element or feature becomes disabled.",
    "example": "<input type=\"checkbox\" click=\"disable\" ondisabled=\"insertbeforebegin:[Disabled!]\"> Disable me",
    "depends_on": [
      "disable"
    ],
    "see_also": [
      "onenabled"
    ]
  },
  "onfocused": {
    "category": "event",
    "description_short": "Triggered when the element gains focus.",
    "example": "<button click=\"focus:#field1\">Focus</button>\n<input type=\"text\" id=\"field1\" onfocused=\"setvalue:[onfocused]\">",
    "depends_on": [
      "focus"
    ]
  },
  "onblur": {
    "category": "event",
    "description_short": "Triggered when the element loses focus.",
    "example": "<button click=\"blur:#field1\">Blur</button>\n<input type=\"text\" id=\"field1\" focus onblur=\"setvalue:[onblur]\">",
    "depends_on": [
      "blur"
    ]
  },
  "onhide": {
    "category": "event",
    "description_short": "Triggered when the element is hidden.",
    "example": "<button click=\"hide\" onhide=\"insertafterend:[Element hidden]\">Hide me</button>",
    "depends_on": [
      "hide"
    ]
  },
  "onshow": {
    "category": "event",
    "description_short": "Triggered when the element is shown.",
    "example": "<div id=\"panel\" bgcolor=\"lightgreen\" hide onshow=\"insertafterend:[ Panel shown]\">Hidden Panel</div>\n<button click=\"show:#panel\">Show Panel</button>",
    "depends_on": [
      "show"
    ]
  },
  "onsubmitted": {
    "category": "event",
    "description_short": "Triggered when a form is submitted.",
    "depends_on": [
      "submit"
    ]
  },
  "padding": {
