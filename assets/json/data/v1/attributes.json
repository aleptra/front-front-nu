  "data-src": {
    "category": "binding",
    "description_short": "Specifies the source URL or endpoint for data to be fetched and bound to the element.",
    "example": "<div data-src=\"https://dummyjson.com/products\" data-iterate=\"products\">\n <b data-get=\"title\"></b>\n</div>",
    "see_also": [
      "data-iterate"
    ]
  },
  "data-iterate": {
    "category": "binding",
    "description_short": "Indicates that the element should iterate over an array from the data source.",
    "example": "<div data-src=\"/api/users\" data-iterate=\"true\">User info here</div>",
    "see_also": [
      "data-src"
    ]
  },
  "escape": {
    "category": "content",
    "description_short": "Escapes HTML or special characters to display as plain text.",
