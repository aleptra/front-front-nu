{
  "workshop": [
    {
      "id": 1,
      "key": "syntaxhighlighting",
      "title": "Basics",
      "mission": "Create your first FTML page and display a Hello World heading.",
      "instructions": [
        "Start the document with the DOCTYPE declaration.",
        "Create the root html element.",
        "Load the Front runtime script before the body closes.",
        "Add a body section inside it.",
        "Inside the body, add a heading that says Hello World."
      ],
      "checks": [
        {
          "id": "c1",
          "label": "DOCTYPE",
          "match": "<!DOCTYPE"
        },
        {
          "id": "c2",
          "label": "html",
          "match": "<html"
        },
        {
          "id": "c3",
          "label": "script",
          "match": "<script"
        },
        {
          "id": "c4",
          "label": "body",
          "match": "<body"
        },
        {
          "id": "c5",
          "label": "h1 Hello World",
          "match": "<h1"
        }
      ],
      "solution": "&lt;!DOCTYPE html&gt;\n&lt;html&gt;\n  &lt;body&gt;\n    &lt;script src=\"https://cdn.front.nu/nightly/front.js\"&gt;&lt;/script&gt;\n    &lt;h1&gt;Hello World&lt;/h1&gt;\n  &lt;/body&gt;\n&lt;/html&gt;",
      "author": "Front Labs"
    }
  ]
}